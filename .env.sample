# ================================================================
# .env — Project-U 환경변수
# cp .env.sample .env 후 값을 채워 사용하세요.
# .env는 절대 git에 커밋하지 마세요.
# ================================================================


# ── 1. DB 설정 (필수) ───────────────────────────────────────────

DB_USER=puuser
# 주의: 특수문자(#, $ 등) 포함 시 단일 따옴표로 감싸세요. 예) DB_PASS='my#pass'
DB_PASS=changeme
DB_NAME=pudb


# ── 2. 포트 (호스트 노출 포트) ──────────────────────────────────
# 다른 서비스와 충돌 시 변경하세요.

# APP_PORT=58000
# UI_PORT=53000
# POSTGRES_PORT=55432


# ── 3. 이미지 태그 ──────────────────────────────────────────────

# APP_TAG=latest
# UI_TAG=latest


# ── 4. 기타 ─────────────────────────────────────────────────────

# TIMEZONE=Asia/Seoul
# COMPOSE_PROJECT_NAME=pu

# PostgreSQL 데이터 볼륨 경로 (기본: ./data)
# DATA_DIR=./data
